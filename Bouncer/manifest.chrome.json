{
  "manifest_version": 3,
  "name": "Twitter For You Filter",
  "version": "1.0.0",
  "description": "Filter annoying tweets from Twitter's For You tab using AI",
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "permissions": [
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://api.anthropic.com/*",
    "https://openrouter.ai/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://huggingface.co/*",
    "https://raw.githubusercontent.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://twitter.com/*", "https://x.com/*"],
      "js": ["dompurify.js", "dist/TwitterAdapter.js", "dist/content.js"],
      "css": ["content.css", "adapters/twitter/twitter.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["popup.html", "popup.css", "dist/popup.js", "browser-polyfill.js", "shared/models.js"],
      "matches": ["https://twitter.com/*", "https://x.com/*"]
    }
  ]
}
