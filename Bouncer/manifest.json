{
  "manifest_version": 3,
  "name": "Bouncer - Heal your feed on X",
  "version": "1.1.2",
  "description": "Remove the stuff you don’t want to see in your X feed. Filter by concept, person, emotion — anything.",
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "permissions": [
    "storage",
    "identity"
  ],
  "host_permissions": [
    "https://x.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*"
      ],
      "js": [
        "browser-polyfill.js",
        "dompurify.js",
        "dist/TwitterAdapter.js",
        "dist/content.js"
      ],
      "css": [
        "content.css",
        "adapters/twitter/twitter.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "popup.html",
        "popup.css",
        "dist/popup.js",
        "browser-polyfill.js",
        "adapters/twitter/fiber-extractor.js",
        "icons/a-bouncer-2x-black.png"
      ],
      "matches": [
        "https://x.com/*"
      ]
    }
  ],
  "key": ""
}
